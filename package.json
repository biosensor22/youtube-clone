{
  "name": "youtube-clone-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"try{const fs=require('node:fs');for(const p of ['.next-dev/lock','.next-dev/dev/lock','.next/lock','.next/dev/lock'])fs.rmSync(p,{force:true})}catch(e){}\"",
    "dev": "node server.mjs",
    "dev:web": "next dev",
    "dev:api": "json-server db.json5 --watch --port 3001",
    "build": "next build",
    "start": "node server.mjs",
    "analyze": "next experimental-analyze",
    "lint": "eslint"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "json-server": "^1.0.0-beta.6",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
